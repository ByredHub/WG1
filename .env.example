# WireGuard Easy
WG_EASY_URL=http://localhost:51821
WG_EASY_PASSWORD=your_wg_easy_password

# WhatsApp (whatsapp-web.js — авторизация через QR при первом запуске)
# Никаких ключей не нужно. При старте сервера в терминале появится QR-код.
# Сессия сохраняется в data/wwebjs_auth/ и не требует повторного сканирования.

# ЮКасса
YUKASSA_SHOP_ID=your_shop_id
YUKASSA_SECRET_KEY=your_secret_key

# JWT Secret (придумай случайную строку)
JWT_SECRET=change_this_to_random_string_32chars

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# Server
PORT=3000
NODE_ENV=production

# Стоимость подписки в рублях
SUBSCRIPTION_PRICE=250

# URL сервиса (для ссылок в платёжных уведомлениях)
APP_URL=https://your-domain.com

# СБП реквизиты (отображаются на странице оплаты)
SBP_PHONE=+79001234567
SBP_BANK=Сбербанк
SBP_NAME=Иван И.

# Платёжный провайдер (manual / platega / yukassa)
PAYMENT_PROVIDER=manual

# Platega
PLATEGA_SHOP_ID=
PLATEGA_SECRET_KEY=
